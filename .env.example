# QUORBIT Protocol — Environment Configuration
# Copy to .env and fill in your values. Never commit .env to version control.

# ── Agent Identity ──────────────────────────────────────────────────────────
# Ed25519 private key (hex-encoded). Generated automatically if left empty.
QUORBIT_AGENT_PRIVATE_KEY=

# Human-readable agent name (optional)
QUORBIT_AGENT_NAME=my-agent

# ── Registry ────────────────────────────────────────────────────────────────
# URL of the QUORBIT registry service
QUORBIT_REGISTRY_URL=http://localhost:8000

# ── Heartbeat ───────────────────────────────────────────────────────────────
# Interval in seconds between heartbeat signals
QUORBIT_HEARTBEAT_INTERVAL=30

# ── Consensus ───────────────────────────────────────────────────────────────
# Maximum number of tolerated faulty agents (BFT threshold)
# Network must have at least 3f+1 agents total
QUORBIT_BFT_FAULT_TOLERANCE=1

# ── Reputation ──────────────────────────────────────────────────────────────
# EMA smoothing factor (alpha), range: 0.0 < alpha <= 1.0
QUORBIT_EMA_ALPHA=0.1

# Minimum reputation score to participate in consensus
QUORBIT_MIN_REPUTATION=0.3

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── BusAI (Proprietary) ─────────────────────────────────────────────────────
# API key for BusAI orchestration layer (required for busai/ module)
BUSAI_API_KEY=
BUSAI_ENDPOINT=http://localhost:9000
