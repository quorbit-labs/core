# QUORBIT Protocol — Environment Configuration
# Copy to .env and fill in values. NEVER commit .env to version control.

# ── Infrastructure ────────────────────────────────────────────────────────────

# Redis connection URL (DB=0/1/2 are used internally; one instance is sufficient)
REDIS_URL=redis://localhost:6379

# PostgreSQL + pgvector DSN
POSTGRES_DSN=postgresql://quorbit:quorbit@localhost:5432/quorbit

# Separate credentials for docker-compose postgres service
POSTGRES_USER=quorbit
POSTGRES_PASSWORD=quorbit
POSTGRES_DB=quorbit

# ── Security ──────────────────────────────────────────────────────────────────

# 32-byte hex salt for shard key computation (HMAC-SHA256)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SERVER_SALT=

# 32-byte hex secret for HMAC nonce signing
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SERVER_SECRET=

# ── Genesis ───────────────────────────────────────────────────────────────────

# Path to genesis_validators JSON file, OR inline JSON string.
# Minimum 11 validators required.
# Example: GENESIS_VALIDATORS=/app/config/genesis_validators.json
GENESIS_VALIDATORS=

# ── Agent Identity ────────────────────────────────────────────────────────────

# Ed25519 private key (hex-encoded). Auto-generated on first run if empty.
QUORBIT_AGENT_PRIVATE_KEY=

QUORBIT_AGENT_NAME=quorbit-node

# ── Reputation ────────────────────────────────────────────────────────────────

QUORBIT_EMA_ALPHA=0.0198
QUORBIT_MIN_REPUTATION=0.30

# ── Logging ───────────────────────────────────────────────────────────────────

LOG_LEVEL=INFO

# ── BusAI (Proprietary) ───────────────────────────────────────────────────────

BUSAI_API_KEY=
BUSAI_ENDPOINT=http://localhost:9000
